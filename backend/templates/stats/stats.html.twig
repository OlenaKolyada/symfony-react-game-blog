<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Statistics</title>
    <style>
        body { font-family: sans-serif; margin: 2em; }
        header img { height: 50px; }
        .stats { margin-top: 2em; }
        table { border-collapse: collapse; width: 300px; }
        td { padding: 8px; border: 1px solid #ccc; }
        footer { margin-top: 2em; }
    </style>
</head>
<body>
<header>
    <img src="/uploads/images/assets/logo.png" alt="Logo">
</header>

<section class="stats">
    <h1>Site Statistics</h1>
    <table>
        <tr><td>Games</td><td>{{ stats.games }}</td></tr>
        <tr><td>News</td><td>{{ stats.news }}</td></tr>
        <tr><td>Reviews</td><td>{{ stats.reviews }}</td></tr>
        <tr><td>Users</td><td>{{ stats.users }}</td></tr>
        <tr><td>Comments</td><td>{{ stats.comments }}</td></tr>
    </table>
</section>

<footer>
    <a href="{{ frontend_url }}/">Home</a> |
    <a href="{{ backend_url }}/admin">Admin Panel</a>
</footer>
</body>
</html>
